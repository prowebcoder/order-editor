// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url = env("PRISMA_DATABASE_URL")
  directUrl = env("PRISMA_DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model AppSettings {
  id                   String   @id @default(cuid())
  shop                 String   @unique
  editWindowMinutes    Int      @default(30)
  allowAddressEdit     Boolean  @default(true)
  allowProductEdit     Boolean  @default(true)
  enableUpsells        Boolean  @default(true)
  codVerification      Boolean  @default(false)
  allowDiscountCodes   Boolean  @default(true)
  upsellProductIds     String   @default("[]")
  upsellCollectionIds  String   @default("[]")
  updatedAt            DateTime @updatedAt
  createdAt            DateTime @default(now())
}

model EditSession {
  id              String   @id @default(cuid())
  shop            String
  orderId         String
  token           String   @unique
  customerEmail   String?
  expiresAt       DateTime
  status          String   @default("ACTIVE")
  paymentStatus   String   @default("PENDING")
  otpRequired     Boolean  @default(false)
  otpVerified     Boolean  @default(false)
  usedAt          DateTime?
  metadata        String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shop, orderId])
  @@index([token, status])
}

model OrderEditLog {
  id          String   @id @default(cuid())
  shop        String
  orderId     String
  editSessionId String?
  changes     String
  priceDelta  Float    @default(0)
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  @@index([shop, orderId, createdAt])
}
