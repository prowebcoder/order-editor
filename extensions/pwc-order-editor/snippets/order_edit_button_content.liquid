{%- if customer and order -%}
  {%- assign ofs = order.id -%}
  <div id="orderflex-order-edit-root-{{ ofs }}">
    <div id="order-edit-inline-error-{{ ofs }}" style="display:none; border:1px solid #fca5a5; background:#fef2f2; color:#991b1b; border-radius:8px; padding:10px 12px; margin:12px 0;"></div>
    <script>
      (function () {
        try {
          var params = new URLSearchParams(window.location.search);
          var code = params.get("order_edit_error");
          if (!code) return;
          var node = document.getElementById("order-edit-inline-error-{{ ofs }}");
          if (!node) return;
          var messages = {
            invalid_link: "This edit link is invalid. Please try again from your order page.",
            order_not_editable: "This order can no longer be edited.",
            edit_window_expired: "The edit window for this order has expired.",
            link_failed: "We could not start order editing right now. Please try again."
          };
          node.textContent = messages[code] || "Unable to open order editor right now.";
          node.style.display = "block";
        } catch (e) {
          /* no-op */
        }
      })();
    </script>
    {%- assign app_base = block.settings.app_base_url | strip -%}
    {%- if app_base == blank -%}
      <div style="border: 1px solid #f59e0b; border-radius: 8px; padding: 14px; margin: 12px 0; background: #fffbeb;">
        Set <strong>App base URL</strong> in this block to enable order editing (example: <code>https://your-app.vercel.app</code>).
      </div>
    {%- else -%}
      {%- comment -%}
        DO NOT pipe replace '//...' across the whole URL — that can corrupt `https://` into `https:/`.
        Only strip whitespace and optionally remove a trailing /order-edit path suffix.
      {%- endcomment -%}
      {%- assign clean_base = app_base | strip -%}
      {%- assign suf = '/order-edit' -%}
      {%- assign suf_len = suf | size -%}
      {%- assign cb_len = clean_base | size -%}
      {%- if cb_len >= suf_len -%}
        {%- assign start = cb_len | minus: suf_len -%}
        {%- assign tail_suf = clean_base | slice: start, suf_len -%}
        {%- if tail_suf == suf -%}
          {%- assign clean_base = clean_base | slice: 0, start | strip -%}
        {%- endif -%}
      {%- endif -%}
      {%- for _i in (1..4) -%}
        {%- assign _last_ch = clean_base | slice: -1, 1 -%}
        {%- if _last_ch == '/' -%}
          {%- assign _clen = clean_base | size | minus: 1 -%}
          {%- if _clen >= 8 -%}
            {%- assign clean_base = clean_base | slice: 0, _clen | strip -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign frame_parent_origin = shop.url | strip -%}
      {%- if request.origin != blank -%}
        {%- assign frame_parent_origin = request.origin | strip -%}
      {%- endif -%}
      {%- assign return_to_absolute = 'https://' | append: shop.permanent_domain | append: request.path -%}
      {%- if request.origin != blank -%}
        {%- assign return_to_absolute = request.origin | append: request.path -%}
      {%- endif -%}
      {%- assign encoded_return_to = return_to_absolute | url_encode -%}
      {%- assign frame_parent_enc = frame_parent_origin | url_encode -%}
      {%- assign edit_href = clean_base
        | append: '/theme-order-edit-link?shop='
        | append: shop.permanent_domain
        | append: '&orderId='
        | append: order.id
        | append: '&return_to='
        | append: encoded_return_to
        | append: '&embed=1&frame_parent='
        | append: frame_parent_enc
      -%}
      <div style="border: 1px solid #e5e7eb; border-radius: 8px; padding: 14px; margin: 12px 0;">
        <div style="font-weight: 600; margin-bottom: 8px;">
          {{ block.settings.heading | escape }}
        </div>
        <p style="margin: 0 0 10px; color: #6b7280; font-size: 14px;">
          Opens as a fullscreen popup on top of your order details. Confirm <strong>App base URL</strong> matches your deployed app (<code>https://…</code>).
        </p>
        <button
          type="button"
          class="orderflex-open-editor-{{ ofs }}"
          data-orderflex-url="{{ edit_href | escape }}"
          style="display:inline-block; border:none; cursor:pointer; background:#111827; color:#ffffff; padding:10px 14px; border-radius:6px; font-weight:600; font-size:15px;"
        >
          {{ block.settings.button_label | escape }}
        </button>
      </div>

      <div
        class="orderflex-editor-overlay-{{ ofs }}"
        style="display:none;"
        aria-hidden="true"
        data-orderflex-root="1"
      >
        <div
          role="dialog"
          aria-modal="true"
          aria-label="{{ block.settings.button_label | escape }}"
          style="position:relative; width:100%; max-width:1100px; height:min(92vh, 900px); max-height:100%; background:#ffffff; border-radius:14px; overflow:hidden; box-shadow:0 25px 80px rgba(0,0,0,0.35); display:flex; flex-direction:column; z-index:1; isolation:isolate; pointer-events:auto;"
        >
          <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; padding:12px 16px; border-bottom:1px solid #e5e7eb; background:#ffffff; flex-shrink:0;">
            <span style="font-weight:600; color:#111827; font-size:16px;">{{ block.settings.button_label | escape }}</span>
            <button
              type="button"
              class="orderflex-close-editor-{{ ofs }}"
              style="border:none; background:#e5e7eb; color:#111827; border-radius:8px; padding:8px 14px; font-weight:600; cursor:pointer; font-size:14px;"
            >
              Close
            </button>
          </div>
          <iframe
            class="orderflex-editor-frame-{{ ofs }}"
            title="{{ block.settings.button_label | escape }}"
            style="flex:1; width:100%; min-height:0; border:0; background:#ffffff; display:block; opacity:1;"
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
          ></iframe>
        </div>
      </div>

      <script>
        (function () {
          function repairEditorUrl(raw) {
            if (!raw) return raw;
            var u = String(raw).trim();
            // Common Liquid mistake: `https:/host` (only one slash after scheme)
            if (/^https:\/[^\/]/i.test(u)) {
              u = "https://" + u.slice("https:/".length);
            }
            if (/^http:\/[^\/]/i.test(u)) {
              u = "http://" + u.slice("http:/".length);
            }
            // Collapse accidental triple slashes after scheme
            u = u.replace(/^https:\/\/\/+/i, "https://").replace(/^http:\/\/\/+/i, "http://");
            return u;
          }

          var id = "{{ ofs }}";
          var openBtn = document.querySelector(".orderflex-open-editor-" + id);
          var overlay = document.querySelector(".orderflex-editor-overlay-" + id);
          var closeBtn = document.querySelector(".orderflex-close-editor-" + id);
          var frame = document.querySelector(".orderflex-editor-frame-" + id);
          if (!openBtn || !overlay || !closeBtn || !frame) return;

          var url = repairEditorUrl(openBtn.getAttribute("data-orderflex-url"));
          if (!url) return;

          /** Move overlay to <body> so theme footers/sticky bars cannot paint above us (fixed + z-index inside sections is trapped). */
          function portalOverlayToBody(host) {
            if (host.getAttribute("data-orderflex-portaled") === "1") return;
            host.setAttribute("data-orderflex-portaled", "1");
            host.style.position = "fixed";
            host.style.top = "0";
            host.style.left = "0";
            host.style.right = "0";
            host.style.bottom = "0";
            host.style.width = "100vw";
            host.style.height = "100vh";
            host.style.margin = "0";
            host.style.padding = "16px";
            host.style.boxSizing = "border-box";
            host.style.flexDirection = "row";
            host.style.flexWrap = "nowrap";
            host.style.alignItems = "center";
            host.style.justifyContent = "center";
            host.style.backgroundColor = "rgba(15, 23, 42, 0.78)";
            host.style.zIndex = "2147483647";
            host.style.isolation = "isolate";
            host.style.overflow = "auto";
            document.body.appendChild(host);
          }

          function openPanel() {
            portalOverlayToBody(overlay);
            overlay.style.display = "flex";
            overlay.setAttribute("aria-hidden", "false");
            if (!frame.getAttribute("src")) {
              frame.setAttribute("src", url);
            }
            document.documentElement.style.overflow = "hidden";
            document.body.style.overflow = "hidden";
          }

          function closePanel() {
            overlay.style.display = "none";
            overlay.setAttribute("aria-hidden", "true");
            document.documentElement.style.overflow = "";
            document.body.style.overflow = "";
            try { frame.removeAttribute("src"); } catch (e) {}
          }

          openBtn.addEventListener("click", function (e) {
            e.preventDefault();
            openPanel();
          });

          closeBtn.addEventListener("click", function () {
            closePanel();
          });

          overlay.addEventListener("click", function (e) {
            if (e.target === overlay) closePanel();
          });

          document.addEventListener("keydown", function (e) {
            if (e.key === "Escape" && overlay.style.display === "flex") {
              closePanel();
            }
          });

          window.addEventListener("message", function (event) {
            var data = event && event.data ? event.data : null;
            if (!data || data.type !== "ORDERFLEX_EDIT_COMPLETE") return;
            closePanel();
            window.location.reload();
          });
        })();
      </script>
    {%- endif -%}
  </div>
{%- endif -%}
